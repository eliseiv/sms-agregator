# =============================================================================
# ПРОД-шаблон окружения sms-agreagtor (домен novirell.shop).
# Скопируй в .env на сервере (deploy/bootstrap.sh делает это автоматически) и
# заполни реальными секретами. РЕАЛЬНЫЙ .env в репозиторий НЕ коммитится
# (.gitignore: .env). Здесь только плейсхолдеры — НИКАКИХ реальных секретов.
# =============================================================================

SERVICE_NAME=SMS Aggregator
APP_ENV=production
PUBLIC_BASE_URL=https://novirell.shop
LOG_LEVEL=INFO
TIMEZONE=Europe/Moscow

# --- PostgreSQL (сервис postgres в compose; согласовать с DATABASE_URL) ---
POSTGRES_USER=sms
POSTGRES_PASSWORD=CHANGE_ME_STRONG
POSTGRES_DB=sms

# --- Database / Redis (для app и migrate) ---
# user/password/db в DATABASE_URL обязаны совпадать с POSTGRES_* выше.
# ВАЖНО (прод): app подключён и к сети default, и к внешней mas-net, где
# контейнеры mail-agregator имеют алиасы `postgres`/`redis`. Неквалифицированные
# имена коллидируют и app может уйти в чужую БД/Redis. Поэтому в проде адресуем
# наши контейнеры по УНИКАЛЬНЫМ именам sms-aggregator-postgres / sms-aggregator-redis
# (container_name из docker-compose.prod.yml), а не по `postgres`/`redis`.
DATABASE_URL=postgresql+asyncpg://sms:CHANGE_ME_STRONG@sms-aggregator-postgres:5432/sms
REDIS_URL=redis://sms-aggregator-redis:6379/0

# --- Admin seed (super_admin) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=CHANGE_ME_STRONG

# --- Sessions / auth (прод: cookie только по HTTPS) ---
SESSION_TTL_SECONDS=1209600
SESSION_ABSOLUTE_TTL_SECONDS=2592000
SETUP_SESSION_TTL_SECONDS=900
COOKIE_SECURE=true
LOGIN_FAILURE_THRESHOLD=5
LOGIN_LOCKOUT_MINUTES=15

# --- Telegram Mini App SSO ---
TG_AUTH_INIT_DATA_TTL_SECONDS=300
TG_PENDING_LINK_TTL_SECONDS=900
TG_MAX_LINKS_PER_USER=10
TELEGRAM_WEBAPP_URL=https://novirell.shop

# --- Telegram Bot / delivery ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_PROXY_URL=
DELIVERY_RETRY_INTERVAL_SECONDS=60
DELIVERY_MAX_ATTEMPTS=10

# --- Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
VERIFY_TWILIO_SIGNATURE=true
TWILIO_SIGNATURE_HEADER=X-Twilio-Signature
